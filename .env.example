# ─── Frontend (Vite) — prefix with VITE_ ────────────────────────────────────
# Firebase config (from Firebase Console → Project Settings → Your apps)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=nutrixquest
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000:web:000

# Gemini AI (from https://aistudio.google.com/app/apikey)
VITE_GEMINI_API_KEY=AIzaSyCLyFm4wtreyAGTz5zzpDtMF3k3237-NYA

# Google Maps (from https://console.cloud.google.com → APIs & Services)
VITE_GOOGLE_MAPS_API_KEY=your_maps_api_key

# Backend URL (set after Cloud Run deployment)
VITE_API_BASE_URL=http://localhost:8000

# ─── Backend (FastAPI) ───────────────────────────────────────────────────────
# Gemini (stored in Secret Manager for production)
GEMINI_API_KEY=AIzaSyCLyFm4wtreyAGTz5zzpDtMF3k3237-NYA

# Firebase Admin SDK (service account JSON path or Secret Manager)
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Frontend URL for CORS (set after Cloud Run deployment)
FRONTEND_URL=http://localhost:5173

# ─── Cloud Run / GCP ─────────────────────────────────────────────────────────
PROJECT_ID=nutrixquest
REGION=asia-south1
